<script defer>
	$(document).ready(function(){
	    let productRelated = $("#widget_products_watched_list");
	    let productRelatedPrev = $("#widget_products_watched_btn .prev");
	    let productRelatedNext = $("#widget_products_watched_btn .next");
        productRelated.slick({
            infinite: true,
            dots: false,
            autoplay: true,
            autoplaySpeed: 2000,
            speed: 700,
            slidesToShow: 4,
            slidesToScroll: 1,
            responsive: [
                {
                    breakpoint: 1000,
                    settings: {
                        slidesToShow: 3,
                    }
                },
                {
                    breakpoint: 600,
                    settings: {
                        slidesToShow: 1,
                        slidesToScroll: 1,
                    }
                }
            ]
        });
        productRelatedNext.click(function() {
            productRelated.slick('slickNext');
            return false;
        });
        productRelatedPrev.click(function() {
            productRelated.slick('slickPrev');
            return false;
        });
	});
</script>            </div>
